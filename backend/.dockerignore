# Keep the build context small and fast.

# Python
__pycache__/
*.py[cod]
*.so
.Python

# Virtual environment (NEVER bundle into the image)
venv/
.venv/
env/

# Editor / OS
.idea/
.vscode/
.DS_Store
Thumbs.db

# Big artefacts
phishing_model.zip
*.zip
.gradio/

# Notebooks, training-only scripts (not part of the runtime backend)
*.ipynb
.ipynb_checkpoints/
save_model_cell.py
app.py                   # the Gradio demo — not used by the backend image

# Git
.git/
.gitignore

# Logs and outputs
*.log
outputs/
results/

# Docker itself
Dockerfile
.dockerignore
docker-compose.yml

# README + extension folder (image only needs backend)
README*.md
extension/
